# E2E Test Environment Variables
# Copy this file to .env.e2e and fill in your actual values
# Then run: source .env.e2e && make test-e2e

# Enable E2E tests (must be "true")
E2E_TEST=true

# Slack Test Channel ID
# Get from: Right-click channel > View channel details
# Format: C1234567890
TEST_CHANNEL_ID=C1234567890

# Bot User ID
# Get from: Slack App settings > OAuth & Permissions
# Or: curl -X POST https://slack.com/api/auth.test -H "Authorization: Bearer xoxb-YOUR-TOKEN"
# Format: U1234567890
BOT_USER_ID=U1234567890

# Slack Bot Token (Bot User OAuth Token)
# Get from: Slack App settings > OAuth & Permissions
# Format: xoxb-...
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Slack App Token (App-Level Token)
# Get from: Slack App settings > Basic Information > App-Level Tokens
# Format: xapp-...
SLACK_APP_TOKEN=xapp-your-app-token-here

# Optional: Override bot configuration for E2E tests
# KIRO_AGENT_KIRO_BINARY_PATH=/path/to/kiro-cli
# KIRO_AGENT_SESSION_DATABASE_PATH=/tmp/kiro-e2e-test.db
